rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — anyone authenticated can read; only owner can write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // allowedAdmins — anyone can do a singular read (needed for pre-auth signup check)
    // Only admins (role == "Admin") can write
    match /allowedAdmins/{email} {
      allow get: if true;
      allow list: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin";
    }

    // Complaints collection
    match /complaints/{complaintId} {
      // Any authenticated user can read complaints
      allow read: if request.auth != null;

      // Any authenticated user can create a complaint
      allow create: if request.auth != null;

      // Any authenticated user can update complaints (for voting + admin actions)
      allow update: if request.auth != null;

      // Allow delete for admin complaint removal
      allow delete: if request.auth != null;
    }
  }
}
